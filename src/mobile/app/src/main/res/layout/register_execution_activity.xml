<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activitys_javaclass.ExercisesActivity"
    android:background="@color/lightgrey">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-12dp">

        <LinearLayout
            android:id="@+id/blueSquare"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/rounded"
            android:backgroundTint="@color/lightblue"
            android:orientation="vertical"
            android:padding="24dp">

        <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Registrar Execução"
        android:textSize="26sp"
        android:fontFamily="@font/roboto_medium"
        android:textColor="@color/white"
        android:layout_marginTop="15dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/blueSquare"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="@drawable/rounded"
            android:layout_margin="10dp"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alongamento Cervical"
                android:textSize="20sp"
                android:fontFamily="@font/roboto_medium"
                android:textColor="@color/black"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3x ao Dia"
                android:textSize="15sp"
                android:fontFamily="@font/roboto_medium"
                android:textColor="@color/grey"
                android:layout_marginStart="10dp"
                android:layout_marginBottom="10dp"/>

        </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/blueSquare"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/rounded"
        android:layout_marginHorizontal="10dp"
        android:padding="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nível de Dor"
            android:textSize="20sp"
            android:fontFamily="@font/roboto_medium"
            android:textColor="@color/black"
            android:layout_marginStart="10dp"
            android:layout_marginBottom="10dp">

        </TextView>

        <LinearLayout
            android:id="@+id/scalePain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded"
            android:layout_marginHorizontal="10dp"
            android:padding="10dp">

            <LinearLayout
                android:id="@+id/line1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:layout_width="57dp"
                    android:layout_height="80dp"
                    android:text="1"
                    android:textSize="20sp"
                    android:textColor="@color/grey"
                    android:background="@drawable/pill"
                    app:backgroundTint="@color/lightgrey"/>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="57dp"
                    android:layout_height="80dp"
                    android:text="2"
                    android:textSize="20sp"
                    android:textColor="@color/grey"
                    android:background="@drawable/pill"
                    app:backgroundTint="@color/lightgrey"
                    android:layout_marginStart="5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="57dp"
                    android:layout_height="80dp"
                    android:text="3"
                    android:textSize="20sp"
                    android:textColor="@color/grey"
                    android:background="@drawable/pill"
                    app:backgroundTint="@color/lightgrey"
                    android:layout_marginStart="5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="57dp"
                    android:layout_height="80dp"
                    android:text="4"
                    android:textSize="20sp"
                    android:textColor="@color/grey"
                    android:background="@drawable/pill"
                    app:backgroundTint="@color/lightgrey"
                    android:layout_marginStart="5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="57dp"
                    android:layout_height="80dp"
                    android:text="5"
                    android:textSize="20sp"
                    android:textColor="@color/grey"
                    android:background="@drawable/pill"
                    app:backgroundTint="@color/lightgrey"
                    android:layout_marginStart="5dp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/line2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="10dp">

                <com.google.android.material.button.MaterialButton
                    android:layout_width="57dp"
                    android:layout_height="80dp"
                    android:text="6"
                    android:textSize="20sp"
                    android:textColor="@color/grey"
                    android:background="@drawable/pill"
                    app:backgroundTint="@color/lightgrey"/>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="57dp"
                    android:layout_height="80dp"
                    android:text="7"
                    android:textSize="20sp"
                    android:textColor="@color/grey"
                    android:background="@drawable/pill"
                    app:backgroundTint="@color/lightgrey"
                    android:layout_marginStart="5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="57dp"
                    android:layout_height="80dp"
                    android:text="8"
                    android:textSize="20sp"
                    android:textColor="@color/grey"
                    android:background="@drawable/pill"
                    app:backgroundTint="@color/lightgrey"
                    android:layout_marginStart="5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="57dp"
                    android:layout_height="80dp"
                    android:text="9"
                    android:textSize="20sp"
                    android:textColor="@color/grey"
                    android:background="@drawable/pill"
                    app:backgroundTint="@color/lightgrey"
                    android:layout_marginStart="5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="57dp"
                    android:layout_height="90dp"
                    android:text="10"
                    android:textSize="20sp"
                    android:textColor="@color/grey"
                    android:background="@drawable/pill"
                    app:backgroundTint="@color/lightgrey"
                    android:layout_marginStart="5dp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>